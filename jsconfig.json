{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@components/*": ["components/*"],
      "@country/*": ["components/country/*"],
      "@layout/*": ["components/layout/*"],
      "@ui/*": ["components/ui/*"],
      "@context/*": ["context/*"],
      "@lib/*": ["lib/*"],
      "@public/*": ["public/*"]
    }
  }
}


